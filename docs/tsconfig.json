{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@antdv/components": ["../components/index.ts"],
      "@antdv/components/*": ["../components/*"]
    },
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "types/*.d.ts",
    "src/**/*",
    "src/**/*.vue"
  ],
  "exclude": [
    "src/**/__tests__/*",
    "plugins/**/*"
  ]
}
