{
  "name": "docs-base",
  "type": "module",
  "version": "0.0.0",
  "sideEffects": [
    "./dist/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./dist/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.js"
    },
    "./global.d.ts": "./global.d.ts",
    "./global": "./global.d.ts",
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "docs:dev": "vite docs",
    "docs:preview": "vite docs preview",
    "test:unit": "vitest",
    "docs:build": "vite docs build",
    "type-check": "vue-tsc --build",
    "build": "tsdown"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@antdv-next/auto-import-resolver": "^1.0.5",
    "@antdv-next/icons": "^1.0.4",
    "@antdv-next/unocss": "^1.0.2",
    "@antfu/eslint-config": "^7.7.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "antdv-next": "^1.1.2",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^2.0.1",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "tsdown": "^0.21.0",
    "typescript": "~5.9.3",
    "unocss": "^66.6.6",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "beta",
    "vite-plugin-dayjs": "^1.0.1",
    "vite-plugin-inspect": "^11.3.3",
    "vite-plugin-tsx-resolve-types": "^1.0.1",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
