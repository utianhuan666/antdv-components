{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": ["node"],
    "noEmit": true
  },
  "include": [
    "vite.config.*",
    "vitest.config.*",
    "cypress.config.*",
    "nightwatch.conf.*",
    "playwright.config.*",
    "eslint.config.*",
    "docs/vite.config.ts",
    "docs/types/*.d.ts",
    "uno.config.ts",
    "plugins/**/*",
    "vite.build.config.ts",
    "vite.esm.config.ts",
    "vite.umd.config.ts"
  ]
}
